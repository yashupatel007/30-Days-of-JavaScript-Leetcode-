/**
 * @param {Function} fn
 * @return {Object}
 */
Array.prototype.groupBy = function(fn) {
    const map={};

    for(const x of this)
    {
        const key = fn(x);
        if(map[key])
        {
            map[key].push(x);
        }
        else
        {
            map[key]=[];
            map[key].push(x);
        }
    }
      return map;
};

