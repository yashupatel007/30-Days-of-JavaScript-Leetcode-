/**
 * @param {Array} arr
 * @param {number} depth
 * @return {Array}
 */
var flat = function (arr, n) {
    const ans=[];
    let recurse = function(currArr,currDepth)
    {
        for(const x of currArr)
        {
            if(Array.isArray(x) && currDepth>0)
                recurse(x,currDepth-1);
            else
                ans.push(x);
        }
    };
    recurse(arr,n);
    return ans;
};
