/**
 * @param {Function} fn
 * @return {Function}
 */
function memoize(fn) {
    //create the object to store the previous result
    //if the calculated result present in the object return ans
    // else calculate and store it in the object

    let store={};
    return function(...args) {
        let key= JSON.stringify(args);
        if(key in store)
            return store[key];
        
        let ans=fn(...args);
        store[key]=ans;
        return ans;
    }
}


